      "type": "multi",
      "options": [
        { "id": "none", "label": "都没有" },
        { "id": "course_internship", "label": "只做过课程实践 / 短期参观式实习" },
        { "id": "one_unrelated", "label": "1 段不相关方向" },
        { "id": "one_relevant", "label": "1 段相关方向的实习" },
        { "id": "two_relevant", "label": "2 段及以上相关方向" },
        { "id": "top_company", "label": "在头部企业（华为/海思/中芯/宁德/字节等）实习过" },
        { "id": "other", "label": "其他（请具体说明）", "type": "text" }
      ],
      "scoring": {
        "options": {
          "none": { "experience": 0 }, "course_internship": { "experience": 8 },
          "one_unrelated": { "experience": 12, "clarity": 4 }, "one_relevant": { "experience": 30, "clarity": 8 },
