    "language": "zh-CN",
    "note": "情境题库——朋友咨询中常用的真实场景，作为关卡 evt_* 题或独立模拟决策环节"
  },
  "scenarios": [
    {
      "id": "scn_offer_compare_salary_platform",
      "gate": "clarity",
      "title": "你拿到 TP-Link 硬件 25K（年包约 36W） 和 华为海思 IC 验证 23K（约 28W）两个 offer，都在深圳。怎么选？",
      "context": "两份 offer 都是技术岗，TP-Link 现金更高、平台较单一；海思平台强但内卷。",
      "type": "single",
      "options": [
        { "id": "tp", "label": "TP-Link，现金更高、生活质量优先" },
        { "id": "hisi", "label": "华为海思，平台和履历更重要" },
        { "id": "negotiate", "label": "先答应海思但同时再谈 TP-Link 涨薪" }
      ],
      "scoring": {
        "options": {
          "tp": { "clarity": 18, "fit": 12 },
          "hisi": { "clarity": 15, "execution": 8 },
          "negotiate": { "clarity": 10, "execution": 12 }
        }
      },
      "commentaryHints": "如果学生 fit 维度偏 WLB/钱，TP-Link 是对的；如果路径偏研发深度，海思更对。"
    },
    {
      "id": "scn_low_gpa_response",
      "gate": "academic",
      "title": "面试官追问：你的 GPA 不算亮眼，你凭什么能跟上我们的强度？",
      "context": "你 GPA 在 3.0-3.3，但有一段相关实习和一个核心课成绩亮眼。",
      "type": "single",
      "options": [
        { "id": "evidence", "label": "用「核心课成绩+后续实习产出」做正面回应" },
        { "id": "avoid", "label": "强调兴趣和热爱，回避具体分数" },
        { "id": "story", "label": "用一个具体故事讲清楚自己怎么补的" }
      ],
      "scoring": {
        "options": {
          "evidence": { "academic": 18, "execution": 8 },
          "avoid": { "academic": 4, "execution": 2 },
          "story": { "academic": 15, "experience": 8 }
        }
      }
    },
    {
      "id": "scn_cross_field_materials_to_semi",
      "gate": "gap",
      "title": "你是材料背景想冲半导体研发，本科只修过 1-2 门相关课。研一第一学期怎么安排？",
      "context": "目标是申请 NUS MSE 后进半导体；申请季 27 Fall。",
      "type": "single",
      "options": [
        { "id": "course_first", "label": "先把半导体物理/工艺基础课补完再说" },
        { "id": "intern_first", "label": "尽快进一段相关实习，边做边学" },
        { "id": "balance", "label": "课程+实习同时启动，并联合做一个垂直项目" },
        { "id": "research", "label": "先找学校的半导体相关课题组做一段科研" }
      ],
      "scoring": {
        "options": {
          "course_first": { "gap": 12, "academic": 8 },
          "intern_first": { "gap": 15, "experience": 12 },
          "balance": { "gap": 22, "execution": 10, "experience": 8 },
          "research": { "gap": 14, "experience": 10 }
        }
      },
      "commentaryHints": "balance 最理想，但执行成本高；intern_first 是朋友常推的——「实习 ≈ 科研，最重要是垂直度」。"
    },
    {
      "id": "scn_shift_work_smic",
      "gate": "fit",
      "title": "中芯国际工艺工程师 offer 落到你头上：需要倒班 + 驻厂上海。年薪 30W，包宿舍。",
      "context": "你性格内向、想要稳定的工作生活节奏，但目前没有更好的 offer 在手。",
      "type": "single",
      "options": [
        { "id": "accept", "label": "去，先存钱+学到流程再说" },
        { "id": "decline", "label": "不去，再等等更合适的" },
        { "id": "redirect", "label": "去但只接受不倒班的岗位（PIE/良率）" }
      ],
      "scoring": {
        "options": {
          "accept": { "fit": 8, "execution": 12 },
          "decline": { "fit": 12, "clarity": 8 },
          "redirect": { "fit": 18, "clarity": 12 }
        }
      },
      "commentaryHints": "工艺工程师朋友打的是红标。redirect 到 PIE/良率 是黑客式答案。"
    },
    {
      "id": "scn_haitou_vs_targeted",
      "gate": "execution",
      "title": "秋招季你投了 30 家进 6 个面试。要不要为剩下的目标公司专门改简历？",
      "context": "你的简历是通用版本，没有针对每家定制。",
      "type": "single",
      "options": [
        { "id": "customize", "label": "为每家公司专门改简历" },
        { "id": "haitou", "label": "继续海投通用简历" },
        { "id": "match_jd", "label": "按 JD 改课程顺序/技能标签，但不大改" }
      ],
      "scoring": {
        "options": {
          "customize": { "execution": 5 },
          "haitou": { "execution": 12 },
          "match_jd": { "execution": 20 }
        }
      },
      "commentaryHints": "朋友原话：海投即可，招聘和申研不一样。一份简历适用所有公司（同岗位）。但按 JD 微调课程/技能是必要的。"
    },
    {
      "id": "scn_company_type_3way",
      "gate": "fit",
      "title": "你同时拿到：中国电信 15W（有北京户口）、字节跳动 40W（无户口）、爱立信 25W（WLB 好）。怎么选？",
      "type": "single",
      "options": [
        { "id": "soe", "label": "中国电信——户口和稳定优先" },
        { "id": "internet", "label": "字节——现金最大化" },
        { "id": "foreign", "label": "爱立信——WLB 和履历" },
        { "id": "internet_then_jump", "label": "字节攒 3 年再跳" }
      ],
      "scoring": {
        "options": {
          "soe": { "fit": 18, "clarity": 10 },
          "internet": { "fit": 18, "clarity": 10 },
          "foreign": { "fit": 18, "clarity": 10 },
          "internet_then_jump": { "fit": 12, "clarity": 18, "execution": 8 }
        }
      },
      "commentaryHints": "没有对错。朋友会看 fit 维度的 priority 排序：钱第一选字节，户口第一选电信，WLB 第一选爱立信。internet_then_jump 显示路径思考更长。"
