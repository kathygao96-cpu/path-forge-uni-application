    {
      "id": "scn_project_storytelling",
      "gate": "experience",
      "title": "面试官问：「这段项目你再做一次会做什么改变？」你怎么答？",
      "context": "这段项目你做了 3 个月，结果还行但有一些坑没填。",
      "type": "single",
      "options": [
        { "id": "perfect", "label": "其实做得挺好，没什么要改的" },
        { "id": "honest_with_plan", "label": "诚实指出 2 个具体改进点和原因" },
        { "id": "generic", "label": "说会更注重沟通和协作" }
      ],
      "scoring": {
        "options": {
          "perfect": { "experience": 4 },
          "honest_with_plan": { "experience": 22, "execution": 8 },
          "generic": { "experience": 8 }
